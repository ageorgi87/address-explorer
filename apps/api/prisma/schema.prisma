generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Departement {
  code     String    @id
  nom      String
  communes Commune[]

  @@map("departements")
}

model Commune {
  id              String      @id
  nom             String
  codePostal      String
  departementCode String
  departement     Departement @relation(fields: [departementCode], references: [code])
  voies           Voie[]

  @@index([departementCode])
  @@index([nom])
  @@map("communes")
}

model Voie {
  id        String   @id
  nom       String
  communeId String
  commune   Commune  @relation(fields: [communeId], references: [id])
  numeros   Numero[]

  @@index([communeId])
  @@index([nom])
  @@map("voies")
}

model Numero {
  id      String  @id
  numero  String
  suffixe String?
  lat     Float
  lon     Float
  voieId  String
  voie    Voie    @relation(fields: [voieId], references: [id])

  @@index([voieId])
  @@map("numeros")
}
